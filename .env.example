# Database (SQLite by default — override with any SQLAlchemy-compatible URL)
DATABASE_URL=sqlite+aiosqlite:///./carouselify.db

# Auth
SECRET=change-me-in-production

# Admin (email of the user who can access /api/admin/stats)
ADMIN_EMAIL=

# Polar.sh (optional - for premium subscriptions)
# Set SUBSCRIPTIONS_ENABLED=true in dev to enable checkout. Leave unset/false in prod until store is verified.
SUBSCRIPTIONS_ENABLED=true
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_ORGANIZATION_ID=
POLAR_PRODUCT_ID=
# "sandbox" for testing, "production" for live
POLAR_SERVER=production

# OpenAI (optional - for AI slide generation)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
